# =============================================================
#  Reglas personalizadas Suricata — local.rules
#  Proyecto Integrado ASIR — César Acevedo Gomez
#  IES Fuengirola 1 — 2025/2026
# =============================================================

# ── Escaneo de puertos ────────────────────────────────────────
alert tcp any any -> any any (msg:"NMAP SYN Scan detectado"; flags:S; sid:1000001; rev:1;)
alert icmp any any -> any any (msg:"ICMP detectado"; sid:1000003; rev:1;)
alert tcp any any -> any 22 (msg:"Conexion SSH detectada"; sid:1000002; rev:1;)

# ── SQL Injection ─────────────────────────────────────────────
alert http any any -> $HOME_NET any (msg:"SQL Injection detectado - UNION SELECT"; flow:to_server; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; classtype:web-application-attack; sid:1000010; rev:1;)
alert http any any -> $HOME_NET any (msg:"SQL Injection detectado - OR 1=1"; flow:to_server; http.uri; content:"or+1=1"; nocase; classtype:web-application-attack; sid:1000011; rev:1;)
alert http any any -> $HOME_NET any (msg:"SQL Injection detectado - DROP TABLE"; flow:to_server; http.uri; content:"DROP"; nocase; content:"TABLE"; nocase; classtype:web-application-attack; sid:1000012; rev:1;)
alert http any any -> $HOME_NET any (msg:"SQL Injection detectado - comilla simple"; flow:to_server; http.uri; content:"'"; classtype:web-application-attack; sid:1000013; rev:1;)

# ── XSS ──────────────────────────────────────────────────────
alert http any any -> $HOME_NET any (msg:"XSS detectado - script tag"; flow:to_server; http.uri; content:"<script>"; nocase; classtype:web-application-attack; sid:1000020; rev:1;)
alert http any any -> $HOME_NET any (msg:"XSS detectado - javascript"; flow:to_server; http.uri; content:"javascript:"; nocase; classtype:web-application-attack; sid:1000021; rev:1;)
alert http any any -> $HOME_NET any (msg:"XSS detectado - onerror"; flow:to_server; http.uri; content:"onerror="; nocase; classtype:web-application-attack; sid:1000022; rev:1;)

# ── Escaneo web ───────────────────────────────────────────────
alert http any any -> $HOME_NET any (msg:"Escaneo web - acceso a /admin"; flow:to_server; http.uri; content:"/admin"; classtype:web-application-attack; sid:1000030; rev:1;)
alert http any any -> $HOME_NET any (msg:"Escaneo web - acceso a /etc/passwd"; flow:to_server; http.uri; content:"/etc/passwd"; classtype:web-application-attack; sid:1000031; rev:1;)
alert http any any -> $HOME_NET any (msg:"Escaneo web - Directory Traversal"; flow:to_server; http.uri; content:"../"; classtype:web-application-attack; sid:1000032; rev:1;)

